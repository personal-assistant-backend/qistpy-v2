generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String               @id @default(cuid())
  phone               String               @unique
  email               String?              @unique
  passwordHash        String
  name                String
  cnic                String               @unique
  role                UserRole             @default(CUSTOMER)
  kycStatus           KycStatus            @default(NOT_SUBMITTED)
  isPhoneVerified     Boolean              @default(false)
  isActive            Boolean              @default(true)
  lastLoginAt         DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  addresses           Address[]
  auditLogs           AuditLog[]           @relation("AuditActor")
  cart                Cart?
  installmentRequests InstallmentRequest[]
  kycDocuments        KycDocument[]
  notifications       Notification[]
  orders              Order[]
  refreshTokens       RefreshToken[]
  vendor              Vendor?

  @@index([role])
  @@index([kycStatus])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model OtpCode {
  id         String    @id @default(cuid())
  phone      String
  codeHash   String
  purpose    String
  attempts   Int       @default(0)
  consumedAt DateTime?
  expiresAt  DateTime
  createdAt  DateTime  @default(now())

  @@index([phone, purpose])
  @@index([expiresAt])
}

model Address {
  id        String   @id @default(cuid())
  userId    String
  label     String
  line1     String
  line2     String?
  cityId    String
  phone     String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  city      City     @relation(fields: [cityId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders    Order[]

  @@index([userId])
}

model Vendor {
  id                 String              @id @default(cuid())
  userId             String              @unique
  businessName       String
  slug               String              @unique
  ntn                String?             @unique
  description        String?
  logoUrl            String?
  phone              String
  email              String?
  status             VendorStatus        @default(PENDING)
  platformFeePercent Decimal             @default(5.00) @db.Decimal(5, 2)
  lateFeeAmount      Decimal             @default(500.00) @db.Decimal(10, 2)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  payouts            Payout[]
  products           Product[]
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  kyc                VendorKyc?
  wallet             VendorWallet?
  walletTxns         WalletTransaction[]

  @@index([status])
}

model VendorKyc {
  id                 String    @id @default(cuid())
  vendorId           String    @unique
  cnicFrontPublicId  String
  cnicBackPublicId   String
  businessLicenseUrl String
  ntnCertificateUrl  String
  bankProofUrl       String
  shopPhotoUrl       String?
  status             KycStatus @default(PENDING)
  reviewedAt         DateTime?
  reviewedById       String?
  rejectionReason    String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  vendor             Vendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([status])
}

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  parentId    String?
  description String?
  imageUrl    String?
  iconUrl     String?
  orderIndex  Int        @default(0)
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  products    Product[]
  seoPages    SeoPage[]

  @@index([parentId])
  @@index([isActive])
}

model Brand {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  logoUrl   String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]

  @@index([isActive])
}

model City {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  addresses Address[]
  seoPages  SeoPage[]

  @@index([isActive])
}

model Product {
  id               String            @id @default(cuid())
  vendorId         String
  categoryId       String
  brandId          String?
  name             String
  slug             String            @unique
  description      String
  shortDescription String?
  cashPrice        Decimal           @db.Decimal(12, 2)
  stock            Int               @default(0)
  sku              String?           @unique
  status           ProductStatus     @default(DRAFT)
  lowestAdvance    Decimal?          @db.Decimal(12, 2)
  lowestMonthly    Decimal?          @db.Decimal(12, 2)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  cartItems        CartItem[]
  plans            InstallmentPlan[]
  orderItems       OrderItem[]
  brand            Brand?            @relation(fields: [brandId], references: [id])
  category         Category          @relation(fields: [categoryId], references: [id])
  vendor           Vendor            @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  images           ProductImage[]
  specs            ProductSpec[]
  variants         ProductVariant[]

  @@index([vendorId, status])
  @@index([categoryId, status])
  @@index([brandId])
  @@index([status, createdAt])
}

model ProductImage {
  id         String  @id @default(cuid())
  productId  String
  publicId   String
  url        String
  alt        String?
  orderIndex Int     @default(0)
  isPrimary  Boolean @default(false)
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, orderIndex])
}

model ProductVariant {
  id         String   @id @default(cuid())
  productId  String
  name       String
  sku        String?  @unique
  stock      Int      @default(0)
  priceDelta Decimal  @default(0) @db.Decimal(10, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductSpec {
  id         String  @id @default(cuid())
  productId  String
  label      String
  value      String
  orderIndex Int     @default(0)
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, orderIndex])
}

model InstallmentPlan {
  id                  String               @id @default(cuid())
  productId           String
  durationMonths      Int
  advanceAmount       Decimal              @db.Decimal(12, 2)
  monthlyAmount       Decimal              @db.Decimal(12, 2)
  markupPercentage    Decimal              @db.Decimal(5, 2)
  markupAmount        Decimal              @db.Decimal(12, 2)
  totalPayable        Decimal              @db.Decimal(12, 2)
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  cartItems           CartItem[]
  product             Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  installmentRequests InstallmentRequest[]
  orderItems          OrderItem[]

  @@unique([productId, durationMonths])
  @@index([productId, isActive])
}

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
}

model CartItem {
  id                String          @id @default(cuid())
  cartId            String
  productId         String
  installmentPlanId String
  quantity          Int             @default(1)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  cart              Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  installmentPlan   InstallmentPlan @relation(fields: [installmentPlanId], references: [id])
  product           Product         @relation(fields: [productId], references: [id])

  @@unique([cartId, productId, installmentPlanId])
  @@index([cartId])
}

model Order {
  id           String               @id @default(cuid())
  orderNumber  String               @unique
  userId       String
  addressId    String
  subtotal     Decimal              @db.Decimal(12, 2)
  totalAdvance Decimal              @db.Decimal(12, 2)
  totalMonthly Decimal              @db.Decimal(12, 2)
  totalPayable Decimal              @db.Decimal(12, 2)
  notes        String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  requests     InstallmentRequest[]
  address      Address              @relation(fields: [addressId], references: [id])
  user         User                 @relation(fields: [userId], references: [id])
  items        OrderItem[]

  @@index([userId, createdAt])
}

model OrderItem {
  id                String              @id @default(cuid())
  orderId           String
  productId         String
  installmentPlanId String
  vendorId          String
  quantity          Int                 @default(1)
  durationMonths    Int
  advanceAmount     Decimal             @db.Decimal(12, 2)
  monthlyAmount     Decimal             @db.Decimal(12, 2)
  totalPayable      Decimal             @db.Decimal(12, 2)
  request           InstallmentRequest?
  installmentPlan   InstallmentPlan     @relation(fields: [installmentPlanId], references: [id])
  order             Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product           Product             @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([vendorId])
}

model InstallmentRequest {
  id                String                   @id @default(cuid())
  orderId           String
  orderItemId       String                   @unique
  customerId        String
  vendorId          String
  productId         String
  installmentPlanId String
  status            InstallmentRequestStatus @default(PENDING)
  approvedById      String?
  approvedByRole    UserRole?
  approvedAt        DateTime?
  rejectionReason   String?
  vendorNotifiedAt  DateTime?
  adminEscalatedAt  DateTime?
  cancelledAt       DateTime?
  cancelledById     String?
  cancellationNote  String?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  customer          User                     @relation(fields: [customerId], references: [id])
  installmentPlan   InstallmentPlan          @relation(fields: [installmentPlanId], references: [id])
  order             Order                    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItem         OrderItem                @relation(fields: [orderItemId], references: [id])
  schedules         InstallmentSchedule[]
  payments          Payment[]

  @@index([customerId, status])
  @@index([vendorId, status])
  @@index([status, createdAt])
}

model InstallmentSchedule {
  id            String                    @id @default(cuid())
  requestId     String
  installmentNo Int
  dueDate       DateTime
  amount        Decimal                   @db.Decimal(12, 2)
  lateFeeAmount Decimal                   @default(0) @db.Decimal(10, 2)
  status        InstallmentScheduleStatus @default(PENDING)
  paidAt        DateTime?
  paidAmount    Decimal?                  @db.Decimal(12, 2)
  createdAt     DateTime                  @default(now())
  updatedAt     DateTime                  @updatedAt
  request       InstallmentRequest        @relation(fields: [requestId], references: [id], onDelete: Cascade)
  payments      Payment[]

  @@unique([requestId, installmentNo])
  @@index([status, dueDate])
  @@index([requestId])
}

model Payment {
  id                String               @id @default(cuid())
  requestId         String
  scheduleId        String?
  method            PaymentMethod
  status            PaymentStatus        @default(INITIATED)
  amount            Decimal              @db.Decimal(12, 2)
  gatewayTxnId      String?
  gatewayResponse   Json?
  screenshotUrl     String?
  reviewedById      String?
  reviewedAt        DateTime?
  reviewNote        String?
  signatureVerified Boolean              @default(false)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  request           InstallmentRequest   @relation(fields: [requestId], references: [id], onDelete: Cascade)
  schedule          InstallmentSchedule? @relation(fields: [scheduleId], references: [id])

  @@index([requestId])
  @@index([status, createdAt])
  @@index([gatewayTxnId])
}

model VendorWallet {
  id                  String    @id @default(cuid())
  vendorId            String    @unique
  pendingBalance      Decimal   @default(0) @db.Decimal(14, 2)
  clearedBalance      Decimal   @default(0) @db.Decimal(14, 2)
  withdrawableBalance Decimal   @default(0) @db.Decimal(14, 2)
  lastRecomputedAt    DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  vendor              Vendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
}

model WalletTransaction {
  id           String   @id @default(cuid())
  vendorId     String
  paymentId    String?
  payoutId     String?
  type         String
  amount       Decimal  @db.Decimal(12, 2)
  balanceAfter Decimal  @db.Decimal(14, 2)
  note         String?
  createdAt    DateTime @default(now())
  payout       Payout?  @relation(fields: [payoutId], references: [id])
  vendor       Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId, createdAt])
  @@index([paymentId])
}

model Payout {
  id              String              @id @default(cuid())
  vendorId        String
  amount          Decimal             @db.Decimal(12, 2)
  status          PayoutStatus        @default(REQUESTED)
  bankAccount     String
  bankName        String
  accountTitle    String
  requestedAt     DateTime            @default(now())
  approvedAt      DateTime?
  paidAt          DateTime?
  rejectedAt      DateTime?
  rejectionReason String?
  adminNote       String?
  updatedAt       DateTime            @updatedAt
  vendor          Vendor              @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  transactions    WalletTransaction[]

  @@index([vendorId, status])
  @@index([status, requestedAt])
}

model KycDocument {
  id                String    @id @default(cuid())
  userId            String
  cnicFrontPublicId String
  cnicBackPublicId  String
  selfiePublicId    String
  salaryProofUrl    String?
  status            KycStatus @default(PENDING)
  reviewedById      String?
  reviewedAt        DateTime?
  rejectionReason   String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model BlogCategory {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  posts     BlogPost[]
}

model BlogPost {
  id              String        @id @default(cuid())
  title           String
  slug            String        @unique
  excerpt         String
  content         String
  coverImageUrl   String?
  categoryId      String?
  language        String        @default("en")
  isPublished     Boolean       @default(false)
  publishedAt     DateTime?
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  category        BlogCategory? @relation(fields: [categoryId], references: [id])

  @@index([isPublished, publishedAt])
  @@index([language])
}

model SeoPage {
  id              String   @id @default(cuid())
  path            String   @unique
  categoryId      String
  cityId          String
  title           String
  metaDescription String
  introHtml       String
  needsReview     Boolean  @default(true)
  isPublished     Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  category        Category @relation(fields: [categoryId], references: [id])
  city            City     @relation(fields: [cityId], references: [id])

  @@unique([categoryId, cityId])
  @@index([isPublished])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  data      Json?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  entity    String
  entityId  String
  metadata  Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  actor     User?    @relation("AuditActor", fields: [actorId], references: [id])

  @@index([entity, entityId])
  @@index([actorId, createdAt])
  @@index([action, createdAt])
}

enum UserRole {
  CUSTOMER
  VENDOR
  ADMIN
}

enum VendorStatus {
  PENDING
  APPROVED
  SUSPENDED
  REJECTED
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  OUT_OF_STOCK
  ARCHIVED
}

enum InstallmentRequestStatus {
  PENDING
  APPROVED
  REJECTED
  ADVANCE_PAID
  ACTIVE
  COMPLETED
  CANCELLED
  DEFAULTED
}

enum InstallmentScheduleStatus {
  PENDING
  PAID
  OVERDUE
  WAIVED
}

enum PaymentStatus {
  INITIATED
  SUCCESS
  FAILED
  REFUNDED
  PENDING_REVIEW
}

enum PaymentMethod {
  JAZZCASH
  EASYPAISA
  BANK_TRANSFER
  RAAST
}

enum PayoutStatus {
  REQUESTED
  APPROVED
  PAID
  REJECTED
}

enum KycStatus {
  NOT_SUBMITTED
  PENDING
  APPROVED
  REJECTED
}

enum NotificationType {
  OTP
  INSTALLMENT_REQUEST_APPROVED
  INSTALLMENT_REQUEST_REJECTED
  ADVANCE_CONFIRMED
  INSTALLMENT_DUE_SOON
  INSTALLMENT_OVERDUE
  PAYMENT_RECEIVED
  VENDOR_NEW_REQUEST
  VENDOR_PAYOUT_APPROVED
  KYC_APPROVED
  KYC_REJECTED
  BROADCAST
}

enum BannerType {
  HERO
  OFFER
}

model Banner {
  id        String     @id @default(cuid())

  type      BannerType
  position  Int

  isActive  Boolean    @default(true)

  badge     String?
  headline  String?
  subtitle  String?

  ctaText   String?
  ctaLink   String?

  imageUrl  String?
  bgColor   String?

  advance   String?
  monthly   String?
  months    Int?
  total     String?

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([type, position], name: "type_position")
}